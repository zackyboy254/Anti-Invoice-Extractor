{
    "company_name": "Sample Global Corp",
    "company_key": "sample_global",
    "detection_keywords": [
        "Sample Global",
        "GLOBAL-INV"
    ],
    "header_rules": {
        "order_number": "Invoice #:\\s*(\\w+)",
        "customer_name": "Bill To:\\s*(.*)"
    },
    "line_item_rules": {
        "header_trigger": "Qty Ordered",
        "stop_trigger": "Subtotal",
        "row_pattern": "(\\w+)\\s+(.*?)\\s+([\\d\\.]+)\\s+([A-Za-z]+)\\s+([\\d\\.]+)",
        "column_map": {
            "product_code": 1,
            "product_description": 2,
            "units": 3,
            "uom": 4,
            "weight": 5
        }
    }
}
